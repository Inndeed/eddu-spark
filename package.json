{
  "name": "eddu-quiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c magenta,cyan \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build && tsup server/index.ts --format esm --platform node --target node20 --out-dir dist-server",
    "start": "node dist-server/index.js",
    "host:create": "tsx scripts/create-host-user.ts",
    "smoke:public": "tsx scripts/smoke-public.ts",
    "smoke:live": "tsx scripts/smoke-live-flow.ts",
    "audit:product": "tsx scripts/audit-product-surface.ts",
    "check:supabase": "tsx scripts/check-supabase-readiness.ts",
    "check:live-smoke": "tsx scripts/check-live-smoke-readiness.ts",
    "typecheck:scripts": "tsc --ignoreConfig --noEmit --target es2023 --module nodenext --moduleResolution nodenext --types node --skipLibCheck scripts/*.ts",
    "verify:release": "npm run audit:product && npm run typecheck:scripts && npm run build && npm run lint && npm run smoke:public",
    "verify:production": "npm run verify:release && npm run check:supabase && npm run check:live-smoke && npm run smoke:live",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
